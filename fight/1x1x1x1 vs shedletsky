def _draw_roblox_sword(surf, hx, hy, angle, f, blade_col, edge_col, hilt_col, blade_len=42):
    """Draw a Roblox-style linked-sword at hand position, rotated."""
    rad = math.radians(angle * f)
    # blade
    bx = hx + math.cos(rad) * blade_len
    by = hy + math.sin(rad) * blade_len
    pygame.draw.line(surf, blade_col, (int(hx), int(hy)), (int(bx), int(by)), 5)
    pygame.draw.line(surf, edge_col,  (int(hx), int(hy)), (int(bx), int(by)), 2)
    # tip shine
    tx = hx + math.cos(rad) * (blade_len - 4)
    ty = hy + math.sin(rad) * (blade_len - 4)
    pygame.draw.circle(surf, WHITE, (int(bx), int(by)), 2)
    # crossguard
    perp = rad + math.pi / 2
    g1 = (int(hx + math.cos(perp) * 7), int(hy + math.sin(perp) * 7))
    g2 = (int(hx - math.cos(perp) * 7), int(hy - math.sin(perp) * 7))
    pygame.draw.line(surf, hilt_col, g1, g2, 4)
    # pommel
    px = hx - math.cos(rad) * 5
    py = hy - math.sin(rad) * 5
    pygame.draw.circle(surf, hilt_col, (int(px), int(py)), 3)


def draw_1x1x1x1(surf, x, y, facing, action, frame, health_pct):
    """Roblox-style 1x1x1x1: dark body, Domino Crown, single red glowing eye, dark linked sword."""
    f = 1 if facing == "right" else -1
    walk_bob = math.sin(frame * 0.35) * 3 if action == "walk" else 0
    leg_swing = math.sin(frame * 0.35) * 8 if action == "walk" else 0

    # ── SHADOW on ground ──
    shadow_surf = pygame.Surface((44, 10), pygame.SRCALPHA)
    pygame.draw.ellipse(shadow_surf, (0, 0, 0, 50), (0, 0, 44, 10))
    surf.blit(shadow_surf, (x - 22, y + 30))

    # ── LEGS (Roblox blocky) ──
    l_leg_x = x - 7
    r_leg_x = x + 7 - LEG_W + 4  # overlap slightly at center
    # left leg
    leg_pts_l = [(l_leg_x - 2, y + 2), (l_leg_x + LEG_W - 2, y + 2),
                 (l_leg_x + LEG_W - 2 + int(leg_swing * 0.3), y + LEG_H),
                 (l_leg_x + int(leg_swing * 0.3), y + LEG_H)]
    pygame.draw.polygon(surf, X_PANTS, leg_pts_l)
    pygame.draw.polygon(surf, X_TORSO_DARK, leg_pts_l, 1)
    # right leg
    leg_pts_r = [(r_leg_x + 2, y + 2), (r_leg_x + LEG_W + 2, y + 2),
                 (r_leg_x + LEG_W + 2 - int(leg_swing * 0.3), y + LEG_H),
                 (r_leg_x + 2 - int(leg_swing * 0.3), y + LEG_H)]
    pygame.draw.polygon(surf, X_PANTS, leg_pts_r)
    pygame.draw.polygon(surf, X_TORSO_DARK, leg_pts_r, 1)
    # shoes
    pygame.draw.rect(surf, X_SHOE, (l_leg_x - 3 + int(leg_swing * 0.3), y + LEG_H - 2, LEG_W + 2, 5))
    pygame.draw.rect(surf, X_SHOE, (r_leg_x + 1 - int(leg_swing * 0.3), y + LEG_H - 2, LEG_W + 2, 5))

    # ── TORSO (Roblox block) ──
    torso_y = y - TORSO_H + 2 + int(walk_bob)
    torso_rect = pygame.Rect(x - TORSO_W // 2, torso_y, TORSO_W, TORSO_H)
    pygame.draw.rect(surf, X_TORSO, torso_rect)
    pygame.draw.rect(surf, X_TORSO_DARK, torso_rect, 2)
    # dark shirt crease details
    pygame.draw.line(surf, X_TORSO_DARK, (x, torso_y + 4), (x, torso_y + TORSO_H - 4), 1)
    # collar V
    pygame.draw.line(surf, (50, 50, 55), (x - 6, torso_y + 2), (x, torso_y + 10), 1)
    pygame.draw.line(surf, (50, 50, 55), (x + 6, torso_y + 2), (x, torso_y + 10), 1)

    # ── HEAD (Roblox block) ──
    head_x = x
    head_y = torso_y - HEAD_H + 2
    head_rect = pygame.Rect(head_x - HEAD_W // 2, head_y, HEAD_W, HEAD_H)
    pygame.draw.rect(surf, X_SKIN, head_rect)
    pygame.draw.rect(surf, (40, 40, 45), head_rect, 2)

    # ── RED GLOWING EYE (right eye only; left is dead/dark) ──
    eye_front_x = head_x + f * 5
    eye_back_x  = head_x - f * 4
    eye_y_pos   = head_y + 12

    # glowing eye aura (pulsing)
    glow_r = 8 + math.sin(frame * 0.12) * 3
    glow_surf = pygame.Surface((int(glow_r * 4), int(glow_r * 4)), pygame.SRCALPHA)
    pygame.draw.circle(glow_surf, (255, 0, 0, 45), (int(glow_r * 2), int(glow_r * 2)), int(glow_r * 2))
    pygame.draw.circle(glow_surf, (255, 20, 20, 80), (int(glow_r * 2), int(glow_r * 2)), int(glow_r))
    surf.blit(glow_surf, (eye_front_x - int(glow_r * 2), eye_y_pos - int(glow_r * 2)))
    # actual eye
    pygame.draw.circle(surf, (255, 30, 30), (eye_front_x, eye_y_pos), 5)
    pygame.draw.circle(surf, (255, 180, 180), (eye_front_x, eye_y_pos), 2)  # bright center
    # dead eye
    pygame.draw.circle(surf, (15, 15, 15), (eye_back_x, eye_y_pos), 4)
    pygame.draw.circle(surf, (30, 30, 30), (eye_back_x, eye_y_pos), 2)
    # sinister mouth line
    pygame.draw.line(surf, (50, 15, 15), (head_x - 5, head_y + 20), (head_x + 5, head_y + 19), 2)

    # ── DOMINO CROWN (iconic hat) ──
    crown_base_y = head_y - 2
    cw, ch = 34, 14
    crown_x = head_x - cw // 2
    # main crown band (white domino with black pips)
    pygame.draw.rect(surf, DOMINO_WHITE, (crown_x, crown_base_y, cw, ch), border_radius=2)
    pygame.draw.rect(surf, DOMINO_BLACK, (crown_x, crown_base_y, cw, ch), 2, border_radius=2)
    # divider line down the middle (domino split)
    pygame.draw.line(surf, DOMINO_BLACK, (head_x, crown_base_y + 2), (head_x, crown_base_y + ch - 2), 2)
    # pips left side (3 pips = domino 3)
    for dx, dy in [(-10, 4), (-6, 9), (-10, 9)]:
        pygame.draw.circle(surf, DOMINO_BLACK, (head_x + dx, crown_base_y + dy), 2)
    # pips right side (2 pips = domino 2)
    for dx, dy in [(6, 4), (10, 9)]:
        pygame.draw.circle(surf, DOMINO_BLACK, (head_x + dx, crown_base_y + dy), 2)
    # crown spikes (5 golden-white spikes)
    for i, sx in enumerate([-14, -7, 0, 7, 14]):
        spike_h = 12 + (i % 2) * 4
        pts = [
            (head_x + sx - 4, crown_base_y),
            (head_x + sx + 4, crown_base_y),
            (head_x + sx, crown_base_y - spike_h)
        ]
        pygame.draw.polygon(surf, DOMINO_WHITE, pts)
        pygame.draw.polygon(surf, DOMINO_BLACK, pts, 1)
        # tiny pip on each spike
        if i % 2 == 0:
            pygame.draw.circle(surf, DOMINO_BLACK, (head_x + sx, crown_base_y - spike_h + 5), 1)

    # ── ARMS + DARK LINKED SWORD ──
    shoulder_y = torso_y + 4 + int(walk_bob)
    arm_color = X_SKIN
    hand_color = (35, 35, 40)

    if action == "slash":
        progress = min(frame / 12.0, 1.0)
        angle = -70 + progress * 150
        rad = math.radians(angle * f)
        # sword arm
        arm_ex = x + f * 18 + math.cos(rad) * 22
        arm_ey = shoulder_y + math.sin(rad) * 22
        pygame.draw.line(surf, arm_color, (x + f * TORSO_W // 2, shoulder_y), (int(arm_ex), int(arm_ey)), 8)
        pygame.draw.rect(surf, hand_color, (int(arm_ex) - 4, int(arm_ey) - 4, 8, 8))
        _draw_roblox_sword(surf, arm_ex, arm_ey, angle, f,
                           blade_col=(70, 70, 75), edge_col=(200, 30, 30), hilt_col=DARK_RED)
        # off arm
        pygame.draw.line(surf, arm_color, (x - f * TORSO_W // 2, shoulder_y), (x - f * 20, shoulder_y + 22), 8)
    elif action == "block":
        bx = x + f * 28
        pygame.draw.line(surf, arm_color, (x + f * TORSO_W // 2, shoulder_y), (bx, shoulder_y), 8)
        pygame.draw.rect(surf, hand_color, (bx - 4, shoulder_y - 4, 8, 8))
        _draw_roblox_sword(surf, bx, shoulder_y, -90, 1,
                           blade_col=(70, 70, 75), edge_col=(200, 30, 30), hilt_col=DARK_RED, blade_len=40)
        # red shield aura
        shield = pygame.Surface((44, 70), pygame.SRCALPHA)
        pygame.draw.ellipse(shield, (255, 0, 0, 35), (0, 0, 44, 70))
        surf.blit(shield, (bx - 22, shoulder_y - 35))
        pygame.draw.line(surf, arm_color, (x - f * TORSO_W // 2, shoulder_y), (x - f * 18, shoulder_y + 20), 8)
    elif action == "ultra":
        # ULTRA SLASH – rapid alternating slashes with red fire trail
        cycle = (frame % 20) / 20.0
        angle = -60 + math.sin(cycle * math.pi * 2) * 120
        rad = math.radians(angle * f)
        arm_ex = x + f * 20 + math.cos(rad) * 24
        arm_ey = shoulder_y + math.sin(rad) * 24
        pygame.draw.line(surf, arm_color, (x + f * TORSO_W // 2, shoulder_y), (int(arm_ex), int(arm_ey)), 9)
        pygame.draw.rect(surf, hand_color, (int(arm_ex) - 4, int(arm_ey) - 4, 8, 8))
        _draw_roblox_sword(surf, arm_ex, arm_ey, angle, f,
                           blade_col=(180, 40, 40), edge_col=(255, 100, 50), hilt_col=GOLD, blade_len=48)
        # fire trail
        for i in range(5):
            ta = angle - i * 18 * f
            tr = math.radians(ta * f)
            tx = arm_ex + math.cos(tr) * (28 + i * 7)
            ty = arm_ey + math.sin(tr) * (28 + i * 7)
            ts = pygame.Surface((14, 14), pygame.SRCALPHA)
            a = max(0, 120 - i * 25)
            pygame.draw.circle(ts, (255, int(80 - i * 15), 0, a), (7, 7), 7 - i)
            surf.blit(ts, (int(tx) - 7, int(ty) - 7))
        # red aura around body
        aura = pygame.Surface((80, 100), pygame.SRCALPHA)
        ar = int(40 + math.sin(frame * 0.25) * 8)
        pygame.draw.ellipse(aura, (255, 0, 0, 30), (40 - ar, 50 - ar, ar * 2, ar * 2))
        surf.blit(aura, (x - 40, torso_y - 10))
        pygame.draw.line(surf, arm_color, (x - f * TORSO_W // 2, shoulder_y), (x - f * 16, shoulder_y + 18), 8)
    elif action == "entangle":
        # Entanglement cast — arms raised, purple energy vortex
        pygame.draw.line(surf, arm_color, (x + f * TORSO_W // 2, shoulder_y), (x + f * 22, shoulder_y - 26), 9)
        pygame.draw.line(surf, arm_color, (x - f * TORSO_W // 2, shoulder_y), (x - f * 22, shoulder_y - 26), 9)
        vr = int(28 + math.sin(frame * 0.4) * 12)
        vs = pygame.Surface((vr * 4, vr * 4), pygame.SRCALPHA)
        pygame.draw.circle(vs, (120, 40, 180, 60), (vr * 2, vr * 2), vr * 2)
        pygame.draw.circle(vs, (180, 60, 255, 100), (vr * 2, vr * 2), vr)
        pygame.draw.circle(vs, (255, 150, 255, 140), (vr * 2, vr * 2), vr // 2)
        surf.blit(vs, (x - vr * 2, shoulder_y - 26 - vr * 2))
    elif action == "stun_slash":
        # reuse slash animation but with blue electric effect
        progress = min(frame / 12.0, 1.0)
        angle = -70 + progress * 150
        rad = math.radians(angle * f)
        arm_ex = x + f * 18 + math.cos(rad) * 22
        arm_ey = shoulder_y + math.sin(rad) * 22
        pygame.draw.line(surf, arm_color, (x + f * TORSO_W // 2, shoulder_y), (int(arm_ex), int(arm_ey)), 8)
        _draw_roblox_sword(surf, arm_ex, arm_ey, angle, f,
                           blade_col=(70, 70, 75), edge_col=(200, 30, 30), hilt_col=DARK_RED)
        pygame.draw.line(surf, arm_color, (x - f * TORSO_W // 2, shoulder_y), (x - f * 20, shoulder_y + 22), 8)
    else:
        # idle – sword arm at side, slight bob
        idle_bob = math.sin(frame * 0.06) * 2
        arm_end_y = shoulder_y + 24 + idle_bob
        pygame.draw.line(surf, arm_color, (x + f * TORSO_W // 2, shoulder_y), (x + f * 20, int(arm_end_y)), 8)
        pygame.draw.rect(surf, hand_color, (x + f * 20 - 4, int(arm_end_y) - 4, 8, 8))
        _draw_roblox_sword(surf, x + f * 20, arm_end_y, 80, f,
                           blade_col=(70, 70, 75), edge_col=(200, 30, 30), hilt_col=DARK_RED, blade_len=36)
        # off arm
        pygame.draw.line(surf, arm_color, (x - f * TORSO_W // 2, shoulder_y), (x - f * 18, int(arm_end_y)), 8)


