def draw_arena(surf, frame, intensity=0.0):
    """intensity 0-1 ramps up red/dark as someone gets low HP."""
    ri = intensity  # 0 = calm, 1 = someone near death

    for y in range(HEIGHT):
        t = y / HEIGHT
        r = int((12 + ri * 30) + t * (25 + ri * 20))
        g = int((6 - ri * 4) + t * (14 - ri * 8))
        b = int((30 - ri * 15) + t * (45 - ri * 20))
        r = max(0, min(255, r))
        g = max(0, min(255, g))
        b = max(0, min(255, b))
        pygame.draw.line(surf, (r, g, b), (0, y), (WIDTH, y))

    ground_top = HEIGHT - 70

    # buildings (darken with intensity)
    for i, (bx, bw, bh) in enumerate([
        (50, 60, 140), (160, 45, 100), (270, 70, 170), (400, 50, 120),
        (520, 80, 155), (650, 40, 90), (740, 65, 130), (870, 55, 110)
    ]):
        shade = int(18 + (i % 3) * 4 - ri * 8)
        shade = max(5, shade)
        pygame.draw.rect(surf, (shade, shade, shade + 5),
                         (bx, ground_top - bh, bw, bh))
        for wy in range(ground_top - bh + 12, ground_top - 10, 18):
            for wx in range(bx + 8, bx + bw - 8, 14):
                lit = ((wx + wy + frame // 90) % 5) != 0
                # windows flicker red when intense
                if lit:
                    wr = int(55 + ri * 60)
                    wg = int(50 - ri * 30)
                    wb = int(25 - ri * 15)
                else:
                    wr, wg, wb = 12, 12, 16
                pygame.draw.rect(surf, (max(0, wr), max(0, wg), max(0, wb)), (wx, wy, 6, 8))

    # ground
    gr = int(40 + ri * 20)
    gg = int(38 - ri * 10)
    gb = int(50 - ri * 10)
    pygame.draw.rect(surf, (max(0, gr), max(0, gg), max(0, gb)), (0, ground_top, WIDTH, 70))
    edge_r = int(80 + ri * 50)
    pygame.draw.line(surf, (min(255, edge_r), 75, int(90 - ri * 30)), (0, ground_top), (WIDTH, ground_top), 3)

    for i in range(0, WIDTH, 50):
        pygame.draw.line(surf, (int(50 + ri * 15), int(48 - ri * 10), int(60 - ri * 10)),
                         (i, ground_top + 2), (i, ground_top + 70), 1)

    # atmospheric embers when intense
    for i in range(int(8 + ri * 16)):
        speed = 0.3 + ri * 0.8
        px = (i * 137 + frame * speed) % WIDTH
        py = 40 + math.sin(frame * 0.012 + i) * 100 + i * 8
        py = py % (ground_top - 20)
        alpha = 30 + ri * 60 + math.sin(frame * 0.03 + i) * 20
        size = 2 + ri * 2
        dot = pygame.Surface((int(size * 3), int(size * 3)), pygame.SRCALPHA)
        cr = int(200 + ri * 55)
        cg = int(160 - ri * 80)
        cb = int(200 - ri * 160)
        pygame.draw.circle(dot, (min(255, cr), max(0, cg), max(0, cb), int(max(0, min(255, alpha)))),
                           (int(size * 1.5), int(size * 1.5)), int(size))
        surf.blit(dot, (int(px), int(py)))


