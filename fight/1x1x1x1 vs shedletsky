# ─── ENTANGLEMENT PROJECTILE ───
entangle_projectiles = []  # {x, y, vx, vy, owner_name, frame, target}

def fire_entangle_projectile(fighter, other):
    """Fire a purple homing orb from 1x1x1x1 toward the opponent."""
    f = 1 if fighter.facing == "right" else -1
    entangle_projectiles.append({
        "x": fighter.x + f * 30,
        "y": fighter.y - 40,
        "vx": f * 8,
        "vy": 0,
        "owner_name": fighter.name,
        "frame": 0,
        "target": other,
    })

def update_entangle_projectiles():
    for proj in entangle_projectiles[:]:
        proj["frame"] += 1
        # slight homing toward target
        tgt = proj["target"]
        dx = tgt.x - proj["x"]
        dy = (tgt.y - 40) - proj["y"]
        dist = math.hypot(dx, dy)
        if dist > 1:
            proj["vx"] += (dx / dist) * 0.5
            proj["vy"] += (dy / dist) * 0.3
        # speed cap
        spd = math.hypot(proj["vx"], proj["vy"])
        if spd > 10:
            proj["vx"] = proj["vx"] / spd * 10
            proj["vy"] = proj["vy"] / spd * 10
        proj["x"] += proj["vx"]
        proj["y"] += proj["vy"]
        # hit detection
        prect = pygame.Rect(int(proj["x"]) - 14, int(proj["y"]) - 14, 28, 28)
        if prect.colliderect(tgt.rect):
            if tgt.action == "block" and tgt.block_timer > 0:
                spawn_sparks(int(proj["x"]), int(proj["y"]), 25)
                tgt.vel_x = (1 if proj["vx"] > 0 else -1) * 4
            else:
                # STUN + popup explosion
                stun_dur = random.randint(240, 300)  # 4-5 secs
                tgt.stun_timer = stun_dur
                tgt.action = "idle"
                tgt.action_frame = 0
                tgt.ultra_active = False
                tgt.take_damage(10)
                tgt.vel_x = (1 if proj["vx"] > 0 else -1) * 7
                tgt.shake = 10
                spawn_ability_effect(tgt.x, tgt.y - 20, DARK_PURPLE, 30)
                spawn_entangle_impact_popups(int(tgt.x), 18)
            entangle_projectiles.remove(proj)
            continue
        # expire after 3 seconds
        if proj["frame"] > 180 or proj["x"] < -50 or proj["x"] > WIDTH + 50:
            entangle_projectiles.remove(proj)

def draw_entangle_projectiles(surf, frame):
    for proj in entangle_projectiles:
        px, py = int(proj["x"]), int(proj["y"])
        pf = proj["frame"]
        # outer glow
        gr = int(18 + math.sin(pf * 0.3) * 5)
        gs = pygame.Surface((gr * 4, gr * 4), pygame.SRCALPHA)
        pygame.draw.circle(gs, (120, 40, 180, 50), (gr * 2, gr * 2), gr * 2)
        pygame.draw.circle(gs, (180, 60, 255, 90), (gr * 2, gr * 2), gr)
        surf.blit(gs, (px - gr * 2, py - gr * 2))
        # core
        pygame.draw.circle(surf, (200, 80, 255), (px, py), 8)
        pygame.draw.circle(surf, (255, 180, 255), (px, py), 4)
        # trailing sparks
        for i in range(4):
            tx = px - proj["vx"] * (i + 1) * 0.6 + random.randint(-3, 3)
            ty = py - proj["vy"] * (i + 1) * 0.6 + random.randint(-3, 3)
            a = max(0, 120 - i * 30)
            ts = pygame.Surface((8, 8), pygame.SRCALPHA)
            pygame.draw.circle(ts, (160, 40, 200, a), (4, 4), 4 - i)
            surf.blit(ts, (int(tx) - 4, int(ty) - 4))

