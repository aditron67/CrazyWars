        opponent_char = "Shedletsky"
    else:
        opponent_char = "1x1x1x1"

    p1 = Fighter(player_char, 200, ground_y - 34, "right", True, {})
    p2 = Fighter(opponent_char, WIDTH - 200, ground_y - 34, "left", mode == "multi", {})

    is_multi = (mode == "multi")

    frame = 0
    game_over = False
    winner = None
    game_over_timer = 0
    round_text_timer = 120
    particles.clear()
    entangle_popups.clear()
    entangle_projectiles.clear()

    while True:
        frame += 1
        clock.tick(60)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                sys.exit()
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE:
                    return "menu"
                if game_over and event.key == pygame.K_RETURN:
                    return "restart"

                if not game_over and round_text_timer <= 0:
                    # ── P1 controls (arrow keys + 1234) ──
                    if p1.stun_timer <= 0:
                        if event.key == pygame.K_1:
                            p1.start_action("slash", 15)
                        elif event.key == pygame.K_2:
                            if p1.start_action("block", 22):
                                p1.block_timer = 22
                        elif event.key == pygame.K_3:
                            p1.activate_ultra()
                        elif event.key == pygame.K_4:
                            p1.activate_admin(p2)

                    # ── P2 controls (WASD + QERF) — only in multiplayer ──
                    if is_multi and p2.stun_timer <= 0:
                        if event.key == pygame.K_q:
                            p2.start_action("slash", 15)
                        elif event.key == pygame.K_e:
                            if p2.start_action("block", 22):
                                p2.block_timer = 22
                        elif event.key == pygame.K_r:
                            p2.activate_ultra()
                        elif event.key == pygame.K_f:
                            p2.activate_admin(p1)

        if not game_over and round_text_timer <= 0:
            keys = pygame.key.get_pressed()

            # ── P1 movement (arrow keys) ──
            if p1.stun_timer <= 0 and p1.action in ("idle", "walk") and not p1.ultra_active:
                if keys[pygame.K_LEFT]:
                    p1.x -= p1.speed
                    p1.action = "walk"
                elif keys[pygame.K_RIGHT]:
                    p1.x += p1.speed
                    p1.action = "walk"
                elif p1.action == "walk":
                    p1.action = "idle"
            if keys[pygame.K_UP] and p1.on_ground and p1.stun_timer <= 0:
                p1.vel_y = -12
                p1.on_ground = False

            # ── P2 movement ──
            if is_multi:
                if p2.stun_timer <= 0 and p2.action in ("idle", "walk") and not p2.ultra_active:
                    if keys[pygame.K_a]:
                        p2.x -= p2.speed
                        p2.action = "walk"
                    elif keys[pygame.K_d]:
                        p2.x += p2.speed
                        p2.action = "walk"
                    elif p2.action == "walk":
                        p2.action = "idle"
                if keys[pygame.K_w] and p2.on_ground and p2.stun_timer <= 0:
                    p2.vel_y = -12
                    p2.on_ground = False
            else:
                # AI controls P2
                ai_update(p2, p1, difficulty=0.7)

            # face opponent
            if p1.action in ("idle", "walk") and p1.stun_timer <= 0:
                p1.facing = "right" if p2.x > p1.x else "left"
            if p2.action in ("idle", "walk") and p2.stun_timer <= 0:
                p2.facing = "right" if p1.x > p2.x else "left"

            # update fighters
            p1.update(p2)
            p2.update(p1)

            # update entangle popups + projectiles
            update_entangle_popups()
            update_entangle_projectiles()

            # check win
            if p1.health <= 0:
                game_over = True
                winner = p2.name
            elif p2.health <= 0:
                game_over = True
                winner = p1.name

        if round_text_timer > 0:
            round_text_timer -= 1

        if game_over:
            game_over_timer += 1

        update_particles()

        # intensity
        lowest_hp = min(p1.health, p2.health) / 100.0
        intensity = max(0.0, 1.0 - lowest_hp)

        # screen shake
        shake_amt = max(p1.shake, p2.shake)
        sx = random.randint(-shake_amt, shake_amt) if shake_amt > 0 else 0
        sy = random.randint(-shake_amt, shake_amt) if shake_amt > 0 else 0

        # ── DRAW ──
        draw_arena(screen, frame, intensity)

        # draw fighters with shake offset
        back = p1 if p1.x < p2.x else p2
        front = p2 if p1.x < p2.x else p1
        back.x += sx; back.y += sy
        back.draw(screen, frame)
        back.x -= sx; back.y -= sy
        front.x += sx; front.y += sy
        front.draw(screen, frame)
        front.x -= sx; front.y -= sy

        draw_particles(screen)
        draw_entangle_projectiles(screen, frame)
        draw_entangle_popups(screen, frame)
        draw_hud(screen, p1, p2, frame)

        # controls reminder
        if is_multi:
            c1 = font_tiny.render("P1: ←/→/↑ Move  1 Slash  2 Block  3 Ultra  4 Admin", True, (100, 100, 100))
            c2 = font_tiny.render("P2: A/D/W Move  Q Slash  E Block  R Ultra  F Admin", True, (100, 100, 100))
            screen.blit(c1, (20, HEIGHT - 34))
            screen.blit(c2, (20, HEIGHT - 18))
        else:
            ctrl = font_tiny.render("←/→ Move | ↑ Jump | 1 Slash | 2 Block | 3 Ultra | 4 Admin | ESC Menu", True, (100, 100, 100))
            screen.blit(ctrl, (WIDTH // 2 - ctrl.get_width() // 2, HEIGHT - 20))

        # round start text
        if round_text_timer > 0:
            if round_text_timer > 60:
                rt = font_big.render("CREATOR  vs  CREATION", True, (200, 60, 60))
            elif round_text_timer > 30:
                rt = font_big.render("THE FINAL BATTLE", True, WHITE)
            else:
                rt = font_big.render("FIGHT!", True, GOLD)
            rt.set_alpha(min(255, round_text_timer * 6))
            screen.blit(rt, (WIDTH // 2 - rt.get_width() // 2, HEIGHT // 2 - 60))

        # game over overlay
        if game_over:
            overlay = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
            overlay.fill((0, 0, 0, min(160, game_over_timer * 3)))
            screen.blit(overlay, (0, 0))

            win_color = RED if winner == "1x1x1x1" else BLUE
            role = "THE CREATION PREVAILS" if winner == "1x1x1x1" else "THE CREATOR STANDS"
            win_txt = font_big.render(f"{winner} WINS!", True, win_color)
            screen.blit(win_txt, (WIDTH // 2 - win_txt.get_width() // 2, HEIGHT // 2 - 60))

            if game_over_timer > 20:
                role_txt = font_med.render(role, True, win_color)
                role_txt.set_alpha(min(255, (game_over_timer - 20) * 8))
                screen.blit(role_txt, (WIDTH // 2 - role_txt.get_width() // 2, HEIGHT // 2 - 5))

            if is_multi and game_over_timer > 30:
                pw = font_small.render(
                    f"{'P1' if winner == p1.name else 'P2'} VICTORY!", True, GOLD)
                screen.blit(pw, (WIDTH // 2 - pw.get_width() // 2, HEIGHT // 2 + 30))

            if game_over_timer > 50:
                restart_txt = font_small.render("ENTER to rematch  |  ESC for menu", True, WHITE)
                screen.blit(restart_txt, (WIDTH // 2 - restart_txt.get_width() // 2, HEIGHT // 2 + 60))

        pygame.display.flip()


# ══════════════════════════════════════════════════════════
#  ENTRY POINT
# ══════════════════════════════════════════════════════════

def main():
    while True:
        chosen = character_select()
        result_mode = mode_select()
        if result_mode is None:
            continue
        while True:
            result = game_loop(chosen, mode=result_mode)
            if result == "restart":
                continue
            else:
                break

if __name__ == "__main__":
    main()




















































































































































































































































