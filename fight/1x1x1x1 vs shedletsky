    (200, 30, 30), (180, 0, 60), (220, 50, 0), (150, 0, 0),
    (255, 50, 50), (200, 0, 80), (160, 20, 20), (100, 0, 0),
]

def spawn_entangle_impact_popups(target_x, count=18):
    """Spawn a burst of error popups on impact."""
    for _ in range(count):
        pw = random.randint(80, 180)
        ph = random.randint(30, 60)
        px = target_x + random.randint(-200, 200)
        py = random.randint(60, HEIGHT - 120)
        vx = random.uniform(-2, 2)
        vy = random.uniform(-1, 1)
        entangle_popups.append({
            "x": px, "y": py, "w": pw, "h": ph,
            "vx": vx, "vy": vy,
            "life": random.randint(40, 90),
            "text": random.choice(POPUP_TEXTS),
            "color": random.choice(POPUP_COLORS),
        })

def update_entangle_popups():
    for p in entangle_popups[:]:
        p["x"] += p["vx"]
        p["y"] += p["vy"]
        p["life"] -= 1
        if p["life"] <= 0:
            entangle_popups.remove(p)

def draw_entangle_popups(surf, frame):
    popup_font = pygame.font.SysFont("Consolas", 14, bold=True)
    title_font = pygame.font.SysFont("Arial", 10)
    for p in entangle_popups:
        alpha = min(255, p["life"] * 6)
        # window border
        rect = pygame.Rect(int(p["x"]), int(p["y"]), p["w"], p["h"])
        # title bar
        tbar = pygame.Rect(rect.x, rect.y, rect.w, 16)
        ws = pygame.Surface((p["w"], p["h"]), pygame.SRCALPHA)
        ws.fill((20, 20, 25, min(220, alpha)))
        pygame.draw.rect(ws, (*p["color"], min(255, alpha)), (0, 0, p["w"], 16))
        # title text
        tt = title_font.render("ERROR", True, WHITE)
        ws.blit(tt, (4, 2))
        # X button
        pygame.draw.rect(ws, (180, 40, 40), (p["w"] - 16, 0, 16, 16))
        xt = title_font.render("X", True, WHITE)
        ws.blit(xt, (p["w"] - 13, 2))
        # body text
        bt = popup_font.render(p["text"], True, p["color"])
        ws.blit(bt, (p["w"] // 2 - bt.get_width() // 2, p["h"] // 2 - bt.get_height() // 2 + 6))
        # border
        pygame.draw.rect(ws, p["color"], (0, 0, p["w"], p["h"]), 2)
        # glitch flicker
        if random.random() < 0.1:
            ws.set_alpha(random.randint(100, 255))
        else:
            ws.set_alpha(alpha)
        surf.blit(ws, (rect.x, rect.y))


# ══════════════════════════════════════════════════════════
#  FIGHTER CLASS  –  Slash / Block / Ultra / Admin abilities
# ══════════════════════════════════════════════════════════

class Fighter:
    def __init__(self, name, x, y, facing, is_player, controls):
        self.name = name
        self.x = x
        self.y = y
        self.facing = facing
        self.is_player = is_player
        self.controls = controls

        self.health = 100
        self.max_health = 100

        self.action = "idle"
        self.action_frame = 0
        self.action_duration = 0
        self.slash_hit = False

        self.vel_x = 0
        self.vel_y = 0
        self.on_ground = True
        self.ground_y = y
        self.hurt_timer = 0
        self.block_timer = 0

        # ULTRA SLASH mechanic: land a block → charges ultra
        self.ultra_charged = False
        self.ultra_active = False
        self.ultra_frame = 0
        self.ultra_hit_cd = 0

        # ADMIN abilities
        self.admin_cd = 0
        self.admin_max_cd = 300  # 5 seconds
        self.entangle_timer = 0  # 1x1x1x1: popups active for this many frames
        self.stun_timer = 0      # stunned = can't move/act

        # combo
        self.combo = 0
        self.combo_timer = 0

        # screen shake contribution
        self.shake = 0

        if name == "1x1x1x1":
            self.slash_dmg = 12
            self.ultra_dmg = 8       # per-hit during ultra (rapid)
            self.speed = 4.5
        else:
            self.slash_dmg = 10
            self.ultra_dmg = 7
            self.speed = 4.0

    @property
    def rect(self):
        return pygame.Rect(self.x - 20, self.y - 70, 40, 104)

    @property
    def attack_rect(self):
        f = 1 if self.facing == "right" else -1
        return pygame.Rect(self.x + f * 10, self.y - 50, f * 55, 65)

    def start_action(self, action, duration):
        if self.stun_timer > 0:
            return False  # stunned
        if self.ultra_active:
            return False
        if self.action != "idle" and self.action != "walk":
            return False
        self.action = action
        self.action_frame = 0
        self.action_duration = duration
        self.slash_hit = False
        return True

    def activate_ultra(self):
        if self.stun_timer > 0:
            return False
        if not self.ultra_charged or self.ultra_active:
            return False
        if self.action not in ("idle", "walk"):
            return False
        self.ultra_charged = False
        self.ultra_active = True
        self.ultra_frame = 0
        self.ultra_hit_cd = 0
        self.action = "ultra"
        self.action_frame = 0
        self.action_duration = 9999  # runs until block
        return True

    def activate_admin(self, other):
        """Admin ability: 1x1x1x1 = Entanglement, Shedletsky = Stun Slash."""
        if self.stun_timer > 0 or self.admin_cd > 0:
            return False
        if not admin_unlocked.get(self.name, False):
            return False
        if self.action not in ("idle", "walk"):
            return False

        self.admin_cd = self.admin_max_cd

        if self.name == "1x1x1x1":
            # ENTANGLEMENT — fire a homing projectile that stuns
            self.action = "entangle"
            self.action_frame = 0
            self.action_duration = 20  # cast animation
            fire_entangle_projectile(self, other)
            spawn_ability_effect(self.x, self.y - 30, DARK_PURPLE, 20)
            return True
        else:
            # STUN SLASH — slash that stuns for 4-5 seconds (240-300 frames)
            self.action = "stun_slash"
            self.action_frame = 0
            self.action_duration = 18
            self.slash_hit = False
            return True

    def update(self, other):
        # timers
        if self.hurt_timer > 0:
            self.hurt_timer -= 1
        if self.block_timer > 0:
            self.block_timer -= 1
        if self.combo_timer > 0:
            self.combo_timer -= 1
        else:
            self.combo = 0
        if self.shake > 0:
            self.shake -= 1
        if self.admin_cd > 0:
            self.admin_cd -= 1

        # stun countdown
        if self.stun_timer > 0:
            self.stun_timer -= 1
            if self.stun_timer == 0:
                self.action = "idle"
                self.action_frame = 0
            # can't do anything while stunned
            # still apply gravity/velocity below
            if not self.on_ground:
                self.vel_y += 0.6
                self.y += self.vel_y
                if self.y >= self.ground_y:
                    self.y = self.ground_y
                    self.vel_y = 0
                    self.on_ground = True
            self.x += self.vel_x
            self.vel_x *= 0.85
            self.x = max(30, min(WIDTH - 30, self.x))
            return

        # (entanglement is now projectile-based, handled externally)

        # ── ULTRA SLASH continuous hits ──
        if self.ultra_active:
            self.ultra_frame += 1
            self.action_frame = self.ultra_frame
            if self.ultra_hit_cd > 0:
                self.ultra_hit_cd -= 1

            # rapid hit every 10 frames
            if self.ultra_hit_cd == 0:
                atk = self.attack_rect
                atk_n = pygame.Rect(min(atk.left, atk.right), atk.top, abs(atk.width), atk.height)
                if atk_n.colliderect(other.rect):
                    if other.action == "block" and other.block_timer > 0:
                        # BLOCKED — ultra ends, blocker gets THEIR ultra charge
                        clash_x = (self.x + other.x) // 2
                        spawn_sparks(clash_x, self.y - 30, 40)
                        self.ultra_active = False
                        self.action = "idle"
                        self.action_frame = 0
                        other.ultra_charged = True
                        other.shake = 8
                        f = 1 if self.facing == "right" else -1
                        self.vel_x = -f * 7
                        other.vel_x = f * 3
                    else:
                        other.take_damage(self.ultra_dmg)
                        self.combo += 1
                        self.combo_timer = 90
                        f = 1 if self.facing == "right" else -1
                        other.vel_x = f * 3
                        self.ultra_hit_cd = 10
                        other.shake = 4
                        col = RED if self.name == "1x1x1x1" else GOLD
                        spawn_hit_effect(other.x, other.y - 20, col, 8)
                        spawn_sparks(other.x + random.randint(-10, 10),
                                     other.y - 30 + random.randint(-10, 10), 6)

            # auto-chase during ultra
            f = 1 if other.x > self.x else -1
            dist = abs(self.x - other.x)
            if dist > 40:
                self.x += f * self.speed * 1.2
            self.facing = "right" if other.x > self.x else "left"

        # ── Normal action progression ──
        elif self.action not in ("idle", "walk"):
            self.action_frame += 1

            # normal slash hit
            if self.action == "slash" and 4 <= self.action_frame <= 8 and not self.slash_hit:
                atk = self.attack_rect
                atk_n = pygame.Rect(min(atk.left, atk.right), atk.top, abs(atk.width), atk.height)
                if atk_n.colliderect(other.rect):
                    self.slash_hit = True
                    if other.action == "block" and other.block_timer > 0:
                        # BLOCKED — blocker earns ultra charge!
                        clash_x = (self.x + other.x) // 2
                        spawn_sparks(clash_x, self.y - 30, 30)
                        other.ultra_charged = True
                        f = 1 if self.facing == "right" else -1
                        other.vel_x = f * 3
                        self.vel_x = -f * 3
                        other.shake = 6
                    else:
                        dmg = self.slash_dmg + self.combo * 2
                        other.take_damage(dmg)
                        self.combo += 1
                        self.combo_timer = 60
                        f = 1 if self.facing == "right" else -1
                        other.vel_x = f * 6
                        other.shake = 5
                        spawn_hit_effect(other.x, other.y - 20,
                                         RED if self.name == "1x1x1x1" else BLUE)

            # stun slash hit (Shedletsky admin)
            if self.action == "stun_slash" and 5 <= self.action_frame <= 10 and not self.slash_hit:
                atk = self.attack_rect
                atk_n = pygame.Rect(min(atk.left, atk.right), atk.top, abs(atk.width), atk.height)
                if atk_n.colliderect(other.rect):
                    self.slash_hit = True
                    if other.action == "block" and other.block_timer > 0:
                        spawn_sparks((self.x + other.x) // 2, self.y - 30, 30)
                        f = 1 if self.facing == "right" else -1
                        other.vel_x = f * 4
                        self.vel_x = -f * 3
                    else:
                        # STUN! 4-5 seconds
                        stun_dur = random.randint(240, 300)
                        other.stun_timer = stun_dur
                        other.action = "idle"
                        other.action_frame = 0
                        other.ultra_active = False
                        other.take_damage(8)
                        f = 1 if self.facing == "right" else -1
                        other.vel_x = f * 8
                        other.shake = 10
                        spawn_ability_effect(other.x, other.y - 20, BLUE, 20)
                        spawn_sparks(other.x, other.y - 30, 20)

            if self.action_frame >= self.action_duration:
                self.action = "idle"
                self.action_frame = 0

        # gravity
        if not self.on_ground:
            self.vel_y += 0.6
            self.y += self.vel_y
            if self.y >= self.ground_y:
                self.y = self.ground_y
                self.vel_y = 0
                self.on_ground = True

        # velocity / friction
        self.x += self.vel_x
        self.vel_x *= 0.85
        self.x = max(30, min(WIDTH - 30, self.x))

    def take_damage(self, dmg):
        self.health = max(0, self.health - dmg)
        self.hurt_timer = 12

    def draw(self, surf, frame):
        if self.hurt_timer > 0 and self.hurt_timer % 4 < 2:
            return
        hp = self.health / self.max_health
        act = self.action
        af = self.action_frame if self.action != "idle" else frame

        # stunned visual — draw character with blue tint overlay
        if self.name == "1x1x1x1":
            draw_1x1x1x1(surf, int(self.x), int(self.y), self.facing, act, af, hp)
        else:
            draw_shedletsky(surf, int(self.x), int(self.y), self.facing, act, af, hp)

        if self.stun_timer > 0:
            # stun overlay: blue electric sparks + "STUNNED" text
            stun_surf = pygame.Surface((60, 90), pygame.SRCALPHA)
            stun_a = int(80 + math.sin(frame * 0.3) * 40)
            stun_surf.fill((50, 100, 255, stun_a))
            surf.blit(stun_surf, (int(self.x) - 30, int(self.y) - 75))
            # electric sparks
            for _ in range(3):
                ex = int(self.x) + random.randint(-20, 20)
                ey = int(self.y) - random.randint(10, 60)
                pygame.draw.circle(surf, (100, 180, 255), (ex, ey), random.randint(2, 5))
            # text
            st = font_tiny.render("STUNNED", True, (100, 180, 255))
            surf.blit(st, (int(self.x) - st.get_width() // 2, int(self.y) - 85))


# ══════════════════════════════════════════════════════════
#  AI OPPONENT  –  slash / block / ultra only
# ══════════════════════════════════════════════════════════

def ai_update(fighter, opponent, difficulty=0.6):
    dist = abs(fighter.x - opponent.x)
    f = 1 if opponent.x > fighter.x else -1
    fighter.facing = "right" if f == 1 else "left"

    if fighter.stun_timer > 0:
        return  # stunned, can't do anything

    if fighter.ultra_active:
        return

    if fighter.action not in ("idle", "walk"):
        return

    # use admin ability if available
    if admin_unlocked.get(fighter.name, False) and fighter.admin_cd == 0 and dist < 100:
        if random.random() < 0.02 * difficulty:
            fighter.activate_admin(opponent)
            return

    # use ultra if charged and close-ish
    if fighter.ultra_charged and dist < 120 and random.random() < 0.06 * difficulty:
        fighter.activate_ultra()
        return

    # react to opponent slash — try to block
    if opponent.action == "slash" and dist < 85 and random.random() < difficulty * 0.85:
        if fighter.start_action("block", 22):
            fighter.block_timer = 22
        return

    # react to opponent ultra — MUST block
    if opponent.ultra_active and dist < 100 and random.random() < difficulty * 0.9:
        if fighter.start_action("block", 25):
            fighter.block_timer = 25
        return

    # attack at close range
    if dist < 70:
        r = random.random()
        if r < 0.05 * difficulty:
            fighter.start_action("slash", 15)
        return

    # occasional jump
    if fighter.on_ground and random.random() < 0.012 * difficulty:
        fighter.vel_y = -12
        fighter.on_ground = False

    # approach aggressively
    if dist > 55:
        fighter.x += f * fighter.speed * 0.7
        fighter.action = "walk"
    else:
        fighter.action = "idle"


