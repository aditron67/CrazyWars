# ─── MUSIC: The Creation of Hatred ───
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MUSIC_FILE = os.path.join(SCRIPT_DIR, "creation_of_hatred.mp3")

def download_music():
    """Download 'The Creation of Hatred' via yt-dlp if not present."""
    if os.path.exists(MUSIC_FILE):
        return True
    try:
        print("Downloading 'The Creation of Hatred'...")
        subprocess.run([
            sys.executable, "-m", "yt_dlp",
            "-x", "--audio-format", "mp3",
            "-o", MUSIC_FILE.replace(".mp3", ".%(ext)s"),
            "--no-playlist",
            "ytsearch1:The Creation of Hatred Roblox"
        ], check=True, timeout=120)
        if os.path.exists(MUSIC_FILE):
            return True
        # yt-dlp may name it slightly differently
        for fname in os.listdir(SCRIPT_DIR):
            if "creation_of_hatred" in fname.lower() and fname.endswith((".mp3", ".m4a", ".webm", ".opus")):
                actual = os.path.join(SCRIPT_DIR, fname)
                if actual != MUSIC_FILE:
                    os.rename(actual, MUSIC_FILE)
                return True
    except Exception as e:
        print(f"Could not download music: {e}")
        print("Place 'creation_of_hatred.mp3' in the fight/ folder to hear music.")
    return False

def start_music():
    if download_music():
        try:
            pygame.mixer.music.load(MUSIC_FILE)
            pygame.mixer.music.set_volume(0.45)
            pygame.mixer.music.play(-1)  # loop forever
        except Exception as e:
            print(f"Could not play music: {e}")

start_music()

