# ─── PARTICLES ───
particles = []

def spawn_sparks(x, y, count=18):
    for _ in range(count):
        angle = random.uniform(0, math.pi * 2)
        speed = random.uniform(3, 9)
        life  = random.randint(10, 25)
        color = random.choice(SPARK_COLORS)
        particles.append({
            "x": x, "y": y,
            "vx": math.cos(angle) * speed,
            "vy": math.sin(angle) * speed - 2,
            "life": life, "max_life": life,
            "color": color, "size": random.uniform(2, 5)
        })

def spawn_hit_effect(x, y, color, count=10):
    for _ in range(count):
        angle = random.uniform(0, math.pi * 2)
        speed = random.uniform(2, 6)
        life  = random.randint(8, 18)
        particles.append({
            "x": x, "y": y,
            "vx": math.cos(angle) * speed,
            "vy": math.sin(angle) * speed - 1,
            "life": life, "max_life": life,
            "color": color, "size": random.uniform(2, 4)
        })

def spawn_ability_effect(x, y, color, count=25):
    for _ in range(count):
        angle = random.uniform(0, math.pi * 2)
        speed = random.uniform(4, 10)
        life  = random.randint(15, 35)
        particles.append({
            "x": x, "y": y,
            "vx": math.cos(angle) * speed,
            "vy": math.sin(angle) * speed,
            "life": life, "max_life": life,
            "color": color, "size": random.uniform(3, 7)
        })

def update_particles():
    for p in particles[:]:
        p["x"] += p["vx"]
        p["y"] += p["vy"]
        p["vy"] += 0.15
        p["life"] -= 1
        if p["life"] <= 0:
            particles.remove(p)

def draw_particles(surf):
    for p in particles:
        alpha = p["life"] / p["max_life"]
        size = p["size"] * alpha
        color = tuple(int(c * alpha) for c in p["color"])
        pygame.draw.circle(surf, color, (int(p["x"]), int(p["y"])), max(1, int(size)))


